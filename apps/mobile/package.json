{
  "name": "@tourose/mobile",
  "main": "expo-router/entry",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "build": "echo \"Mobile native builds run via EAS — see eas.json\""
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@hookform/resolvers": "^5.2.1",
    "@supabase/supabase-js": "^2.110.7",
    "@tanstack/react-query": "^5.84.1",
    "@tourose/contracts": "workspace:*",
    "@tourose/design-tokens": "workspace:*",
    "@tourose/shared": "workspace:*",
    "expo": "~57.0.7",
    "expo-constants": "~57.0.6",
    "expo-dev-client": "~6.0.12",
    "expo-font": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-notifications": "~0.32.11",
    "expo-router": "~57.0.7",
    "expo-splash-screen": "~57.0.4",
    "expo-sqlite": "~16.0.8",
    "expo-status-bar": "~57.0.1",
    "expo-symbols": "~57.0.1",
    "expo-web-browser": "~57.0.1",
    "nativewind": "^4.1.23",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.62.0",
    "react-native": "0.86.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.7"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "jest": "^29.7.0",
    "jest-expo": "~57.0.1",
    "react-test-renderer": "19.2.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~6.0.3"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|nativewind|react-native-css-interop)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    }
  }
}
