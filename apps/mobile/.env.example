# Copier vers .env pour le développement local. Aucun secret réel ici.

# Supabase (valeurs locales typiques après `pnpm supabase:start`)
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key

# MapLibre style / tiles URL (jamais les tuiles OSM communautaires en production)
EXPO_PUBLIC_MAP_STYLE_URL=https://demotiles.maplibre.org/style.json

# Notifications : credentials configurés via EAS Secrets, pas dans ce fichier
EXPO_PUBLIC_NOTIFICATIONS_ENABLED=false
